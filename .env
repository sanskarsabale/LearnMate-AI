# ============================================================
# LearnMate AI — Environment Variables Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ── Flask Core ───────────────────────────────────────────────
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///learnmate.db

# ── IBM watsonx.ai ───────────────────────────────────────────
# Obtain from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=LUMGiADkShR5Im2tt2kUyO4nPrqRandR2lZgZ5iEyiU6

# Your IBM Cloud project ID (watsonx.ai project)
WATSONX_PROJECT_ID=d4e2e9ca-382c-44dd-997a-eb8a30cccf18

# Regional endpoint — update to match your IBM Cloud region
# us-south: https://us-south.ml.cloud.ibm.com
# eu-de   : https://eu-de.ml.cloud.ibm.com
# jp-tok  : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ── IBM Granite Model IDs ─────────────────────────────────────
# Primary chat/instruction model
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# Faster lightweight model for quick tasks
GRANITE_MINI_MODEL_ID=ibm/granite-3-2b-instruct

# ── Admin Account (auto-created on first run) ─────────────────
ADMIN_EMAIL=admin@learnmate.ai
ADMIN_PASSWORD=Admin@123456

# ── Application Settings ──────────────────────────────────────
APP_NAME=LearnMate AI
MAX_TOKENS=1024
TEMPERATURE=0.7
TOP_P=0.95
